# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# LLM Configuration (existing)
XAI_API_KEY=your-xai-api-key

# Redis Configuration (existing)
REDIS_URL=redis://localhost:6379

# LangGraph Configuration
LANGGRAPH_THREAD_POOL_SIZE=10

# OAuth login — active provider: "adobe" or "google".
# Leave the selected provider's client id/secret blank to run in Demo Mode.
AUTH_PROVIDER=google
# Public base URL of the app. REQUIRED in production (e.g.
# https://varoai.martinkrakowski.com); defaults to localhost for dev only.
APP_BASE_URL=http://localhost:3000
# Secret used to sign session cookies (HMAC). REQUIRED in production — set a
# long random value (e.g. `openssl rand -hex 32`). If unset, a random
# per-process key is used, so every restart/redeploy logs all users out.
SESSION_SECRET=
# Token gating the one-time POST /api/projects/adopt-orphans recovery endpoint.
# Leave unset to keep that endpoint disabled (403); set + send as the
# `x-migration-token` header only when running the recovery.
MIGRATION_TOKEN=

# Adobe IMS (OAuth Web App credential from the Adobe Developer Console)
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_REDIRECT_URI=http://localhost:3000/auth/callback
ADOBE_IMS_ORIGIN=https://ims-na1.adobelogin.com
ADOBE_SCOPES=openid,AdobeID,profile,email

# Google (OAuth client, type "Web application", in Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
GOOGLE_SCOPES=openid email profile
