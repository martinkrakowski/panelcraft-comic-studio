# =============================================
# PanelCraft Comic Studio - Environment Variables
# =============================================

# --- LangSmith (Tracing & Debugging) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=panelcraft-comic-demo
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Image Generation (Choose one or both) ---

# Grok Imagine (xAI) - Recommended for this demo
XAI_API_KEY=xai-...

# Google Gemini (Alternative/Backup)
GOOGLE_GENERATIVE_AI_API_KEY=...

# --- Database (Supabase or local) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# --- Local Development ---
# SQLite (for quick local persistence)
DATABASE_URL="file:./.data/panelcraft.db"

# --- Optional: Future Firefly Integration ---
# ADOBE_FIREFLY_API_KEY=...
# ADOBE_FIREFLY_CLIENT_ID=...

# --- App Configuration ---
NODE_ENV=development
PORT=3001

# --- Frontend (Next.js) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Security ---
# JWT_SECRET=your-super-secret-jwt-key-here
